# Release signing — copy this file to `keystore.properties` (repo root) and fill in
# real values. The real keystore.properties and *.jks files are gitignored and
# must NEVER be committed.
#
# Generate an upload keystore once with:
#   keytool -genkey -v -keystore celvo-upload.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias celvo-upload
#
# storeFile is resolved relative to the repo root.

storeFile=celvo-upload.jks
storePassword=CHANGE_ME
keyAlias=celvo-upload
keyPassword=CHANGE_ME
